# All keys are OPTIONAL. The app works fully offline with bundled factors and
# the no-key UK Carbon Intensity API. Provide keys only to enable upgrades.

# Electricity Maps free tier (live grid intensity, one zone per key).
ELECTRICITY_MAPS_API_KEY=

# Climatiq (optional richer emission factors). Server-side only.
CLIMATIQ_API_KEY=

# Default demo region for the live grid signal when none is keyed.
NEXT_PUBLIC_DEFAULT_GRID_ZONE=GB
